<?xml version="1.0" encoding="utf-8"?>
<!-- Pins nuget.org as the only package source so machine-level feeds (e.g. a
     corporate Azure Artifacts source in the user profile) can't leak into this
     repo — with central package management + warnings-as-errors, an extra
     unmapped or unreachable source fails the build (NU1507/NU1900). -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
