@namespace Filer.Ui.Pages
@page "/"

<PageTitle>Filer</PageTitle>

<h1>Filer</h1>
<p>Your documents, organised and searchable.</p>
<AuthorizeView>
    <Authorized>
        <p><a href="documents">Browse your documents</a> — or manage your
            <a href="folders">folders</a> and <a href="tags">tags</a>.</p>
    </Authorized>
    <NotAuthorized>
        <p class="text-muted"><a href="login">Sign in</a> to manage your documents, folders and tags.</p>
    </NotAuthorized>
</AuthorizeView>
