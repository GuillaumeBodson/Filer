@namespace Filer.Ui.Pages
@page "/documents"
@using Filer.ApiClient.Generated.Models
@using Filer.Ui.Documents
@using Filer.Ui.Formatting
@using Filer.Ui.Search
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IDocumentsService DocumentsApi
@inject ISearchService SearchApi
@inject NavigationManager Navigation

<PageTitle>Documents — Filer</PageTitle>

<h1>Documents</h1>

<DocumentUpload OnUploaded="ReloadAsync" />

@* The URL is the single source of truth for filters and paging: shareable,
   back-button friendly, and folder/tag views (#138/#139) deep-link into it.
   A submitted search is global and ranked (/search, #142); a deep link that
   combines ?q= with a folder/tag keeps the substring filter inside that scope. *@
<form class="filters" role="search" @onsubmit="ApplySearch">
    <input id="search" type="search" aria-label="Search documents"
           placeholder="Search documents…" @bind="_searchInput" />
    <button type="submit" class="btn btn-primary">Search</button>
</form>

@if (SearchMode)
{
    <p class="active-filters">
        Results for <span class="filter-chip">“@Q”</span>
        — <a href="documents">clear search</a>
    </p>
}
else if (HasActiveFilters)
{
    <p class="active-filters">
        Filtered
        @if (!string.IsNullOrWhiteSpace(Q))
        {
            <span class="filter-chip">text: “@Q”</span>
        }
        @if (FolderId is not null)
        {
            <span class="filter-chip">folder</span>
        }
        @if (TagId is not null)
        {
            <span class="filter-chip">tag</span>
        }
        — <a href="documents">clear filters</a>
    </p>
}

@if (_loading)
{
    <LoadingIndicator Message="@(SearchMode ? "Searching…" : "Loading documents…")" />
}
else if (_problem is not null)
{
    <ErrorState Problem="_problem" OnRetry="LoadAsync" />
}
else if (Loaded && Rows.Count == 0)
{
    @if (SearchMode)
    {
        <EmptyState Title="No results"
                    Description="@($"Nothing matches “{Q}”.")">
            <a href="documents">Clear search</a>
        </EmptyState>
    }
    else if (HasActiveFilters)
    {
        <EmptyState Title="No matching documents"
                    Description="No documents match the current filters.">
            <a href="documents">Clear filters</a>
        </EmptyState>
    }
    else
    {
        <EmptyState Title="No documents yet"
                    Description="Documents you upload will show up here." />
    }
}
else if (Loaded)
{
    @* In search mode rows come back most relevant first (opaque score, 03);
       the browse list stays newest first. Same table either way. *@
    <table class="doc-table">
        <thead>
            <tr>
                <th scope="col">Name</th>
                <th scope="col">Size</th>
                <th scope="col">Status</th>
                <th scope="col">Added</th>
            </tr>
        </thead>
        <tbody>
            @foreach (DocumentRow row in Rows)
            {
                <tr>
                    <td class="doc-name"><a href="documents/@row.Id">@row.FileName</a></td>
                    <td class="doc-size">@ByteSize.Format(row.SizeBytes)</td>
                    <td><DocumentStatusBadge Status="@row.Status" /></td>
                    <td class="doc-date">@row.CreatedAt?.LocalDateTime.ToString("d")</td>
                </tr>
            }
        </tbody>
    </table>

    <nav class="pager" aria-label="Pagination">
        <button type="button" class="btn" disabled="@(CurrentPage <= 1)"
                @onclick="() => GoToPage(CurrentPage - 1)">Previous</button>
        <span class="pager-status" aria-live="polite">
            Page @CurrentPage of @TotalPages
            (@TotalCount @(SearchMode
                ? TotalCount == 1 ? "result" : "results"
                : TotalCount == 1 ? "document" : "documents"))
        </span>
        <button type="button" class="btn" disabled="@(CurrentPage >= TotalPages)"
                @onclick="() => GoToPage(CurrentPage + 1)">Next</button>

        <label class="pager-size">
            Per page
            <select value="@CurrentPageSize" @onchange="ChangePageSize">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
        </label>
    </nav>
}

@code {
    private PagedResultOfDocumentListItemResponse? _page;
    private PagedResultOfSearchHitResponse? _searchPage;
    private ProblemDetailsView? _problem;
    private bool _loading = true;
    private string? _searchInput;
    private (Guid?, Guid?, string?, int, int)? _loadedKey;

    [Parameter, SupplyParameterFromQuery(Name = "folderId")] public Guid? FolderId { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "tagId")] public Guid? TagId { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "q")] public string? Q { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "page")] public int? Page { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "pageSize")] public int? PageSize { get; set; }

    private int CurrentPage => Page is > 0 ? Page.Value : 1;
    private int CurrentPageSize => PageSize is > 0 ? PageSize.Value : 20;
    private bool HasActiveFilters => FolderId is not null || TagId is not null || !string.IsNullOrWhiteSpace(Q);

    /// <summary>
    /// Ranked global search (#142): a bare <c>?q=</c>. Combined with a folder or
    /// tag, <c>q</c> stays the browse list's substring filter instead.
    /// </summary>
    private bool SearchMode => !string.IsNullOrWhiteSpace(Q) && FolderId is null && TagId is null;

    private bool Loaded => SearchMode ? _searchPage is not null : _page is not null;

    private int TotalPages => Math.Max((SearchMode ? _searchPage?.TotalPages : _page?.TotalPages) ?? 1, 1);

    private long TotalCount => (SearchMode ? _searchPage?.TotalCount : _page?.TotalCount) ?? 0;

    /// <summary>The row shape both modes render — one table, two envelopes.</summary>
    private sealed record DocumentRow(Guid? Id, string? FileName, long SizeBytes, string? Status, DateTimeOffset? CreatedAt);

    private IReadOnlyList<DocumentRow> Rows => SearchMode
        ? [.. (_searchPage?.Items ?? []).Select(h => new DocumentRow(h.Id, h.FileName, h.SizeBytes ?? 0, h.Status, h.CreatedAt))]
        : [.. (_page?.Items ?? []).Select(i => new DocumentRow(i.Id, i.FileName, i.SizeBytes ?? 0, i.Status, i.CreatedAt))];

    protected override async Task OnParametersSetAsync()
    {
        // Same-page navigations re-run this; only reload when the query changed.
        (Guid?, Guid?, string?, int, int) key = (FolderId, TagId, Q, CurrentPage, CurrentPageSize);
        if (key == _loadedKey)
        {
            return;
        }

        _loadedKey = key;
        _searchInput = Q;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _problem = null;
        try
        {
            if (SearchMode)
            {
                SearchPageResult result = await SearchApi.SearchAsync(
                    new SearchQuery(Q!, CurrentPage, CurrentPageSize));
                _searchPage = result.Page;
                _problem = result.Problem;
                _page = null;
            }
            else
            {
                DocumentsPageResult result = await DocumentsApi.ListAsync(
                    new DocumentsQuery(FolderId, TagId, Q, CurrentPage, CurrentPageSize));
                _page = result.Page;
                _problem = result.Problem;
                _searchPage = null;
            }
        }
        finally
        {
            _loading = false;
        }
    }

    /// <summary>Refreshes the current page in place (e.g. after an upload).</summary>
    private Task ReloadAsync() => LoadAsync();

    private void ApplySearch()
    {
        // A submitted search leaves any folder/tag browsing context — it is a
        // global ranked query, not a filter inside the current scope. Clearing
        // the box returns to the plain browse list.
        bool blank = string.IsNullOrWhiteSpace(_searchInput);
        string uri = Navigation.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["folderId"] = blank ? FolderId : null,
            ["tagId"] = blank ? TagId : null,
            ["q"] = blank ? null : _searchInput,
            ["page"] = null,
            ["pageSize"] = CurrentPageSize == 20 ? null : CurrentPageSize,
        });
        Navigation.NavigateTo(uri);
    }

    private void GoToPage(int page) =>
        NavigateWith(text: Q, page: page);

    private void ChangePageSize(ChangeEventArgs e) =>
        NavigateWith(text: Q, page: 1, pageSize: int.TryParse((string?)e.Value, out int size) ? size : null);

    private void NavigateWith(string? text, int page, int? pageSize = null)
    {
        string uri = Navigation.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["folderId"] = FolderId,
            ["tagId"] = TagId,
            ["q"] = string.IsNullOrWhiteSpace(text) ? null : text,
            ["page"] = page == 1 ? null : page,
            ["pageSize"] = (pageSize ?? CurrentPageSize) == 20 ? null : pageSize ?? CurrentPageSize,
        });
        Navigation.NavigateTo(uri);
    }
}
