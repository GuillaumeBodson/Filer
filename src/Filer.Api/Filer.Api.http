@Filer.Api_HostAddress = http://localhost:8080
@email = demo@filer.local
@password = Passw0rd!

### Register a new account
POST {{Filer.Api_HostAddress}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Login to obtain an access token
# @name login
POST {{Filer.Api_HostAddress}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Refresh tokens (rotates: exchanges the refresh token for a new pair)
# @name refresh
POST {{Filer.Api_HostAddress}}/api/v1/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{login.response.body.$.refreshToken}}"
}

### Current user profile (uses the token from the login response above)
GET {{Filer.Api_HostAddress}}/api/v1/auth/me
Authorization: Bearer {{login.response.body.$.accessToken}}

### Logout (revokes the refresh-token family; requires auth) -> 204
POST {{Filer.Api_HostAddress}}/api/v1/auth/logout
Authorization: Bearer {{login.response.body.$.accessToken}}
Content-Type: application/json

{
  "refreshToken": "{{login.response.body.$.refreshToken}}"
}

###
